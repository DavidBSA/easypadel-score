generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SessionFormat {
  SINGLE
  MIXED
  TEAM
}

enum SessionStatus {
  LOBBY
  ACTIVE
  COMPLETE
}

enum MatchStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
}

enum ScoreStatus {
  PENDING
  CONFIRMED
  CONFLICT
}

model Session {
  id                 String        @id @default(cuid())
  code               String        @unique
  organiserPin       String
  format             SessionFormat
  status             SessionStatus @default(LOBBY)
  courts             Int
  pointsPerMatch     Int           @default(21)
  servesPerRotation  Int           @default(4)
  maxPlayers         Int?
  scheduledAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  players  Player[]
  matches  Match[]
  devices  Device[]

  @@index([code])
}

model Player {
  id          String   @id @default(cuid())
  sessionId   String
  name        String
  partnerName String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  device  Device?

  @@index([sessionId])
}

model Match {
  id            String       @id @default(cuid())
  sessionId     String
  queuePosition Int
  courtNumber   Int?
  status        MatchStatus  @default(PENDING)
  teamAPlayer1  String
  teamAPlayer2  String
  teamBPlayer1  String
  teamBPlayer2  String
  pointsA       Int?
  pointsB       Int?
  scoreStatus   ScoreStatus?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  session          Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  scoreSubmissions ScoreSubmission[]

  @@index([sessionId, status])
  @@index([sessionId, queuePosition])
}

model ScoreSubmission {
  id          String   @id @default(cuid())
  matchId     String
  deviceId    String
  pointsA     Int
  pointsB     Int
  submittedAt DateTime @default(now())

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id])

  @@unique([matchId, deviceId])
  @@index([matchId])
}

model Device {
  id          String   @id @default(cuid())
  sessionId   String
  isOrganiser Boolean  @default(false)
  courtNumber Int?
  playerId    String?  @unique
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  session     Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  player      Player?           @relation(fields: [playerId], references: [id])
  submissions ScoreSubmission[]

  @@index([sessionId])
}

model BugReport {
  id          String    @id @default(cuid())
  pageUrl     String
  sessionCode String?
  userNote    String?
  status      String    @default("OPEN")
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
}